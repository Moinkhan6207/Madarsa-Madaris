# =============================================================================
# Idara Management System - Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# For production deployment (Vercel, Render, etc.), set these in the platform dashboard.
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Primary: Base URL for the backend API.
# Must include the /api/v1 suffix or the app will append it automatically.
NEXT_PUBLIC_API_URL=https://madarsa-backend-k4yz.onrender.com/api/v1

# Fallback/Alias: Some scripts may reference this name instead.
NEXT_PUBLIC_API_BASE_URL=https://madarsa-backend-k4yz.onrender.com/api/v1

# -----------------------------------------------------------------------------
# Domain Configuration (REQUIRED for production)
# -----------------------------------------------------------------------------
# The main domain where the frontend is hosted.
# Used for subdomain routing logic in middleware.ts and SEO metadata.
# Example: madarsa-saas.com
NEXT_PUBLIC_MAIN_DOMAIN=madarsa-saas.com
