// =============================================================================
// NeonDB PostgreSQL Configuration
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "typedSql"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgcrypto]
}

enum TenantStatus {
  DRAFT
  PENDING_ACTIVATION
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum InstitutionType {
  SMALL_LOCAL_MADARSA
  RESIDENTIAL_MADARSA
  HYBRID_DEENI_SCHOOL
  TRUST_RUN_IDARA
  MASJID_MADARSA_COMBINED
  OTHER
}

enum DivisionType {
  MALE
  FEMALE
  BOTH
}

enum OnboardingStepStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum StudentStatus {
  LEAD
  APPLIED
  UNDER_REVIEW
  ADMITTED
  ACTIVE
  PROMOTED
  TRANSFERRED
  DROPPED
  PASSED_OUT
  ALUMNI
}

enum StudentGuardianRelation {
  FATHER
  MOTHER
  BROTHER
  SISTER
  UNCLE
  AUNT
  GRANDPARENT
  SPOUSE
  OTHER
}

enum StudentHistoryEvent {
  CREATED
  STATUS_CHANGED
  PROFILE_UPDATED
  BRANCH_CHANGED
  SESSION_CHANGED
  PROGRAM_CHANGED
  CLASS_CHANGED
  GUARDIAN_ADDED
  GUARDIAN_UPDATED
  GUARDIAN_REMOVED
  SPONSOR_LINKED
  SPONSOR_UNLINKED
  SOFT_DELETED
}

model Tenant {
  id               String          @id @default(uuid())
  slug             String          @unique
  displayName      String
  legalName        String?
  status           TenantStatus    @default(DRAFT)
  institutionType  InstitutionType
  primaryEmail     String?
  primaryPhone     String?
  customDomain     String?
  isDomainVerified Boolean         @default(false)
  deletedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  profile          InstitutionProfile?
  settings         TenantSettings?
  branding         TenantBranding?
  websiteSettings  WebsiteSettings?
  branches         Branch[]
  academicSessions AcademicSession[]
  pages            Page[]
  leads            Lead[]
  media            Media[]
  onboarding       OnboardingProgress?
  subscriptions    PlanSubscription[]
  features         TenantFeature[]
  users            User[]
  auditLogs        AuditLog[]
  slugHistory      TenantSlugHistory[]
  stats            TenantStats?
  students         Student[]
  sponsors         Sponsor[]
  studentGuardians StudentGuardian[]
  studentSponsors  StudentSponsor[]
  studentHistory   StudentHistory[]
}

model TenantSlugHistory {
  id        String   @id @default(uuid())
  tenantId  String
  oldSlug   String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([oldSlug])
  @@index([tenantId])
}

model InstitutionProfile {
  id                 String       @id @default(uuid())
  tenantId           String       @unique
  shortName          String?
  trustName          String?
  registrationNumber String?
  email              String?
  phone              String?
  alternatePhone     String?
  addressLine1       String?
  addressLine2       String?
  city               String?
  state              String?
  country            String?
  postalCode         String?
  websiteUrl         String?
  establishedYear    Int?
  principalName      String?
  description        String?
  divisionType       DivisionType @default(BOTH)
  hasHostel          Boolean      @default(false)
  hasTransport       Boolean      @default(false)
  hasMasjidLinkedOps Boolean      @default(false)
  hasMultiBranch     Boolean      @default(false)
  deletedAt          DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  tenant             Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantSettings {
  id                 String   @id @default(uuid())
  tenantId           String   @unique
  primaryLanguage    String   @default("en")
  secondaryLanguage  String?
  timezone           String   @default("Asia/Kolkata")
  dateFormat         String   @default("DD-MM-YYYY")
  currencyCode       String   @default("INR")
  sessionStartMonth  Int?
  allowArabicInput   Boolean  @default(true)
  allowUrduInput     Boolean  @default(true)
  defaultCountryCode String?  @default("+91")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantBranding {
  id                 String   @id @default(uuid())
  tenantId           String   @unique
  logoUrl            String?
  coverImageUrl      String?
  faviconUrl         String?
  primaryColor       String?
  secondaryColor     String?
  accentColor        String?
  tagline            String?
  publicContactEmail String?
  publicContactPhone String?
  facebookUrl        String?
  instagramUrl       String?
  youtubeUrl         String?
  whatsappNumber     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Branch {
  id           String       @id @default(uuid())
  tenantId     String
  code         String?
  name         String
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  country      String?
  postalCode   String?
  phone        String?
  email        String?
  headName     String?
  isPrimary    Boolean      @default(false)
  status       BranchStatus @default(ACTIVE)
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  students     Student[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([createdAt])
  @@index([status])
}

model AcademicSession {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  students  Student[]

  @@index([tenantId])
  @@index([createdAt])
  @@index([isCurrent])
}

model OnboardingProgress {
  id               String               @id @default(uuid())
  tenantId         String               @unique
  accountStep      OnboardingStepStatus @default(COMPLETED)
  profileStep      OnboardingStepStatus @default(NOT_STARTED)
  brandingStep     OnboardingStepStatus @default(NOT_STARTED)
  branchStep       OnboardingStepStatus @default(NOT_STARTED)
  sessionStep      OnboardingStepStatus @default(NOT_STARTED)
  adminStep        OnboardingStepStatus @default(NOT_STARTED)
  finalizationStep OnboardingStepStatus @default(NOT_STARTED)
  completedAt      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Plan {
  id            String             @id @default(uuid())
  code          String             @unique
  name          String
  description   String?
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  subscriptions PlanSubscription[]
}

model PlanSubscription {
  id        String    @id @default(uuid())
  tenantId  String
  planId    String
  startsAt  DateTime
  endsAt    DateTime?
  isCurrent Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [planId], references: [id])

  @@index([tenantId])
}

model TenantFeature {
  id         String   @id @default(uuid())
  tenantId   String
  featureKey String
  isEnabled  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureKey])
  @@index([tenantId])
}

model User {
  id              String     @id @default(uuid())
  tenantId        String?
  fullName        String
  email           String
  phone           String?
  passwordHash    String
  isEmailVerified Boolean    @default(false)
  isActive        Boolean    @default(true)
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  tenant          Tenant?    @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userRoles       UserRole[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([createdAt])
}

model Role {
  id              String           @id @default(uuid())
  tenantId        String?
  code            String
  name            String
  description     String?
  isSystemRole    Boolean          @default(false)
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, code])
}

model Permission {
  id              String           @id @default(uuid())
  code            String           @unique
  name            String
  description     String?
  createdAt       DateTime         @default(now())
  rolePermissions RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String?
  actorUserId String?
  entityType  String
  entityId    String
  action      String
  oldValue    Json?
  newValue    Json?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  requestId   String?
  createdAt   DateTime @default(now())
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, entityType])
}

// =============================================================================
// CMS & Website Builder Models
// =============================================================================

model WebsiteSettings {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  siteTitle       String?
  metaDescription String?
  faviconUrl      String?
  logoUrl         String?
  primaryColor    String?  @default("#10b981")
  secondaryColor  String?  @default("#0f172a")
  accentColor     String?  @default("#f59e0b")
  footerText      String?
  contactEmail    String?
  contactPhone    String?
  whatsappNumber  String?
  facebookUrl     String?
  instagramUrl    String?
  twitterUrl      String?
  linkedinUrl     String?
  youtubeUrl      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Page {
  id              String      @id @default(uuid())
  tenantId        String
  title           String
  slug            String
  isPublished     Boolean     @default(false)
  isHomePage      Boolean     @default(false)
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  canonicalUrl    String?
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  blocks          PageBlock[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  // Composite index for public page lookups
  @@index([tenantId, isPublished, deletedAt, isHomePage])
  // Index for slug lookups within tenant
  @@index([tenantId, slug, isPublished, deletedAt])
}

model PageBlock {
  id        String   @id @default(uuid())
  pageId    String
  tenantId  String
  type      String   // e.g., 'hero', 'about', 'courses', 'stats', 'testimonials', 'gallery', 'cta', 'donation-banner'
  content   Json     // stores text, image URLs, etc.
  config    Json     // stores layout config, colors, etc.
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([tenantId])
}

model Lead {
  id        String   @id @default(uuid())
  tenantId  String
  type      String   // 'ADMISSION', 'CONTACT', 'INQUIRY', 'VOLUNTEER'
  name      String?
  email     String?
  phone     String?
  message   String?
  formData  Json     // stores text, image URLs, etc.
  status    String   @default("NEW") // NEW, IN_PROGRESS, CONVERTED, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([email])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model Media {
  id        String   @id @default(uuid())
  tenantId  String
  url       String
  type      String   // 'IMAGE', 'VIDEO', 'DOCUMENT'
  fileName  String?
  fileSize  Int?
  mimeType  String?
  altText   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([createdAt])
  @@index([type])
}

model TenantStats {
  id             String   @id @default(uuid())
  tenantId       String   @unique
  totalStudents  Int      @default(0)
  totalTeachers  Int      @default(0)
  totalLeads     Int      @default(0)
  totalPages     Int      @default(0)
  totalBranches  Int      @default(0)
  lastUpdatedAt  DateTime @default(now())
  createdAt      DateTime @default(now())
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Student {
  id                String         @id @default(uuid())
  tenantId          String
  branchId          String
  academicSessionId String?
  admissionNumber   String
  rollNumber        String?
  firstName         String
  lastName          String?
  fullName          String
  gender            String?
  dateOfBirth       DateTime?
  admissionDate     DateTime      @default(now())
  phone             String?
  email             String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  country           String?
  postalCode        String?
  status            StudentStatus  @default(LEAD)
  isOrphan          Boolean        @default(false)
  isNeedy           Boolean        @default(false)
  isSponsored       Boolean        @default(false)
  currentProgram    String?
  currentClass      String?
  leadSource        String?
  notes             String?
  deletedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch            Branch         @relation(fields: [branchId], references: [id], onDelete: Restrict)
  academicSession   AcademicSession? @relation(fields: [academicSessionId], references: [id], onDelete: SetNull)
  guardians         StudentGuardian[]
  sponsors          StudentSponsor[]
  history           StudentHistory[]

  @@unique([tenantId, admissionNumber])
  @@unique([tenantId, rollNumber])
  @@index([tenantId, status, deletedAt, createdAt])
  @@index([tenantId, branchId, status, deletedAt])
  @@index([tenantId, academicSessionId, deletedAt])
  @@index([tenantId, fullName])
  @@index([tenantId, phone])
  @@index([tenantId, isOrphan, isSponsored, isNeedy])
  @@index([branchId])
}

model StudentGuardian {
  id              String                  @id @default(uuid())
  tenantId        String
  studentId       String
  relation        StudentGuardianRelation
  fullName        String
  phone           String
  alternatePhone  String?
  email           String?
  occupation      String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  country         String?
  postalCode      String?
  isPrimary       Boolean                 @default(false)
  notes           String?
  deletedAt       DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  tenant          Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student         Student                 @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId, studentId, deletedAt])
  @@index([tenantId, phone])
  @@index([studentId, isPrimary, deletedAt])
}

model Sponsor {
  id            String           @id @default(uuid())
  tenantId      String
  name          String
  phone         String?
  email         String?
  organization  String?
  notes         String?
  deletedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentLinks  StudentSponsor[]

  @@unique([tenantId, name, phone])
  @@index([tenantId, deletedAt])
  @@index([tenantId, name])
}

model StudentSponsor {
  id           String    @id @default(uuid())
  tenantId     String
  studentId    String
  sponsorId    String
  supportLabel String?
  amount       Decimal?  @db.Decimal(12, 2)
  currencyCode String?   @default("INR")
  startDate    DateTime?
  endDate      DateTime?
  notes        String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sponsor      Sponsor   @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@index([tenantId, studentId, deletedAt])
  @@index([tenantId, sponsorId, deletedAt])
  @@index([tenantId, studentId, sponsorId, deletedAt])
}

model StudentHistory {
  id          String              @id @default(uuid())
  tenantId    String
  studentId   String
  event       StudentHistoryEvent
  fieldName   String?
  oldValue    Json?
  newValue    Json?
  metadata    Json?
  changedBy   String?
  changedAt   DateTime            @default(now())
  createdAt   DateTime            @default(now())
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student     Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId, studentId, changedAt])
  @@index([tenantId, event, changedAt])
}
