# =============================================================================
# Idara Management System - Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=5001
API_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# Database (NeonDB / PostgreSQL)
# -----------------------------------------------------------------------------
# Required: Connection string for Prisma (with pgBouncer compat)
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# Optional: Direct connection URL for Prisma Migrate (NeonDB requires this)
# If using NeonDB, this should point to the non-pooled connection endpoint
DIRECT_URL=postgresql://username:password@host/database?sslmode=require

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# REQUIRED: Must be at least 32 characters. Use a cryptographically secure random string.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-64-character-random-hex-string-minimum-32-chars
JWT_EXPIRES_IN=24h

# REQUIRED: Must be at least 32 characters. MUST be different from JWT_SECRET.
JWT_REFRESH_SECRET=change-this-to-a-different-64-character-random-hex-string
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12

# PRODUCTION WARNING: Do NOT use '*' in production. Set to your exact frontend origin.
# Example: https://madarsa-frontend-6im4.onrender.com
CORS_ORIGIN=*

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
# REQUIRED for production: Public URL where this backend is hosted.
# Used for generating file URLs and health check responses.
APP_URL=https://madarsa-backend-k4yz.onrender.com

# REQUIRED for production: URL of the frontend application.
# Used in email templates for login links and redirects.
FRONTEND_URL=https://madarsa-frontend-6im4.onrender.com

# -----------------------------------------------------------------------------
# Redis (Optional but recommended for production)
# -----------------------------------------------------------------------------
# If set, enables Redis caching and BullMQ job queues.
# If omitted, falls back to in-memory cache and synchronous job processing.
# Format: redis://username:password@host:port or rediss:// for TLS
REDIS_URL=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FILE=logs/app.log

# -----------------------------------------------------------------------------
# Tenant Configuration
# -----------------------------------------------------------------------------
DEFAULT_TENANT_SUBDOMAIN=default
MAX_TENANTS_PER_USER=5

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
# Development defaults use MailHog on localhost:1025
# Production: Use a real SMTP service (SendGrid, AWS SES, Mailgun, etc.)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@madarsa.cloud

# -----------------------------------------------------------------------------
# Development Only
# -----------------------------------------------------------------------------
# Set to 'true' to disable rate limiting during local development
DISABLE_RATE_LIMIT=false
