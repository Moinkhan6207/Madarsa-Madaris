# =============================================================================
# Idara Management System - Mobile App Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# For EAS Build / Expo, set these in the EAS dashboard or use eas.json secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Base URL for the backend API (without the /api/v1 suffix).
# The app will automatically append /api/v1 to all API calls.
EXPO_PUBLIC_API_URL=https://madarsa-backend-k4yz.onrender.com

# -----------------------------------------------------------------------------
# Web / Deep Linking (REQUIRED for production)
# -----------------------------------------------------------------------------
# The base URL of the web frontend. Used for shared links and OAuth callbacks.
EXPO_PUBLIC_WEB_BASE_URL=https://madarsa-saas.com

# -----------------------------------------------------------------------------
# Optional: Analytics, Push Notifications, etc.
# -----------------------------------------------------------------------------
# Add any third-party service keys here (e.g., Firebase, Sentry, Mixpanel).
# Remember: EXPO_PUBLIC_ variables are bundled into the app and are NOT secret.
# For secret values, use EAS secrets or native config plugins instead.
# EXPO_PUBLIC_SENTRY_DSN=
# EXPO_PUBLIC_FIREBASE_API_KEY=
